{
  "name": "agenda-backend",
  "version": "2.0.0",
  "description": "API de Agenda de Contatos - Node.js + Pglite",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "node --watch index.js",
    "start": "node index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unique": "node --experimental-vm-modules --no-warnings test/test-unique-phone.js",
    "lint": "eslint . --fix"
  },
  "keywords": [
    "agenda",
    "api",
    "nodejs",
    "pglite"
  ],
  "author": "Seu Nome",
  "license": "MIT",
  "dependencies": {
    "@electric-sql/pglite": "^0.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^8.56.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}